# Project Epic - Environment Variables
# Copy this file to .env and fill in your API keys

# Required for Claude agents (Planner uses Gemini, others use Claude)
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional for Gemini agents (Planner, Support, Healer)
GOOGLE_AI_API_KEY=your-google-key-here

# Optional for OpenAI (if you want GPT models)
OPENAI_API_KEY=sk-your-openai-key-here

# Server configuration
EPIC_HOST=127.0.0.1
EPIC_PORT=8766
