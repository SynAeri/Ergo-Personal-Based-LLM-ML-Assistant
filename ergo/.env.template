# Ergo Configuration Template
# Copy this file to .env and fill in your values
# Never commit .env to version control

# =============================================================================
# MODEL API CREDENTIALS
# =============================================================================

# Anthropic (for Opus - expensive reasoning/code tasks)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI (for Gemini - general chat covered by plan)
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# OpenAI (optional - if using for embeddings or other tasks)
OPENAI_API_KEY=your_openai_api_key_here

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Database type: sqlite or postgres
DATABASE_TYPE=sqlite

# SQLite path (relative to project or absolute)
SQLITE_PATH=~/.local/share/ergo/activity.db

# PostgreSQL connection (only if DATABASE_TYPE=postgres)
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ergo
# POSTGRES_USER=ergo
# POSTGRES_PASSWORD=your_postgres_password_here

# =============================================================================
# STORAGE PATHS
# =============================================================================

# Base data directory
ERGO_DATA_DIR=~/.local/share/ergo

# Event storage
ERGO_EVENTS_DIR=~/.local/share/ergo/events

# Session summaries
ERGO_SUMMARIES_DIR=~/.local/share/ergo/session_summaries

# Screenshots (when explicitly captured)
ERGO_SCREENSHOTS_DIR=~/.local/share/ergo/screenshots

# Audio recordings (when voice mode enabled)
ERGO_AUDIO_DIR=~/.local/share/ergo/audio

# Repo snapshots
ERGO_REPO_SNAPSHOTS_DIR=~/.local/share/ergo/repo_snapshots

# Model cache (for local models)
ERGO_MODELS_DIR=~/.local/share/ergo/models

# Config files
ERGO_CONFIG_DIR=~/.config/ergo

# Backups
ERGO_BACKUP_DIR=~/.local/share/ergo/backups

# =============================================================================
# DAEMON CONFIGURATION
# =============================================================================

# Window check interval in seconds
WINDOW_CHECK_INTERVAL=5

# Pattern detection interval in seconds
PATTERN_CHECK_INTERVAL=50

# Session timeout in minutes (time before creating new session)
SESSION_TIMEOUT=30

# =============================================================================
# PRIVACY SETTINGS
# =============================================================================

# Privacy filter patterns (comma-separated, case-insensitive)
PRIVACY_IGNORE_PATTERNS=password,token,secret,.env,bitwarden,keepass,vault,credentials

# Applications to completely ignore (comma-separated)
PRIVACY_IGNORE_APPS=

# Websites to ignore (comma-separated domains)
PRIVACY_IGNORE_DOMAINS=

# Enable screenshot capture (false by default for privacy)
ENABLE_SCREENSHOTS=false

# Screenshot capture mode: never, manual, on_error, checkpoint
SCREENSHOT_MODE=manual

# =============================================================================
# MEMORY SETTINGS
# =============================================================================

# Ephemeral context window in minutes
EPHEMERAL_CONTEXT_MINUTES=90

# Working memory retention in hours
WORKING_MEMORY_HOURS=24

# Long-term memory retention in days (0 = forever)
LONGTERM_MEMORY_DAYS=0

# Enable automatic session summaries
ENABLE_SESSION_SUMMARIES=true

# Summary generation interval in hours
SUMMARY_INTERVAL_HOURS=4

# =============================================================================
# MODEL ROUTING
# =============================================================================

# Default model for general chat: gemini, opus, local
DEFAULT_CHAT_MODEL=gemini

# Model for code review and debugging: opus, gemini
CODE_REVIEW_MODEL=opus

# Model for session summaries: local, gemini
SUMMARY_MODEL=local

# Model for event tagging: local, rules
EVENT_TAGGING_MODEL=local

# Local model path (if using local models)
LOCAL_MODEL_PATH=~/.local/share/ergo/models/llama-3.2-3b.gguf

# =============================================================================
# INTERVENTION ENGINE
# =============================================================================

# Enable proactive interventions
ENABLE_INTERVENTIONS=true

# Stuck window detection threshold in minutes
STUCK_THRESHOLD_MINUTES=30

# Context switch excessive threshold (switches per hour)
CONTEXT_SWITCH_THRESHOLD=20

# Quiet hours (no interventions during this time)
QUIET_HOURS_START=22:00
QUIET_HOURS_END=08:00

# Minimum intervention confidence (0.0 to 1.0)
MIN_INTERVENTION_CONFIDENCE=0.75

# =============================================================================
# API SERVER CONFIGURATION
# =============================================================================

# Local orchestrator API
ORCHESTRATOR_HOST=127.0.0.1
ORCHESTRATOR_PORT=8765

# UI server
UI_HOST=127.0.0.1
UI_PORT=3000

# IPC socket path (for daemon communication)
IPC_SOCKET_PATH=/tmp/ergo-daemon.sock

# =============================================================================
# VOICE SETTINGS (OPTIONAL - DISABLED BY DEFAULT)
# =============================================================================

# Enable voice mode
ENABLE_VOICE=false

# Voice mode: push_to_talk, always_on
VOICE_MODE=push_to_talk

# Local STT model path
STT_MODEL_PATH=~/.local/share/ergo/models/whisper-small.gguf

# Voice activation keyword (for always_on mode)
VOICE_ACTIVATION_KEYWORD=hey_ergo

# =============================================================================
# NEOVIM PLUGIN SETTINGS
# =============================================================================

# Enable Neovim integration
ENABLE_NVIM_PLUGIN=true

# Neovim socket path
NVIM_SOCKET_PATH=/tmp/ergo-nvim.sock

# =============================================================================
# REMOTE ACCESS (FUTURE - DISABLED BY DEFAULT)
# =============================================================================

# Enable remote access
ENABLE_REMOTE_ACCESS=false

# Remote access method: tailscale, relay
REMOTE_ACCESS_METHOD=tailscale

# Relay server URL (if using relay)
# RELAY_SERVER_URL=

# Authentication token for remote access
# REMOTE_AUTH_TOKEN=

# =============================================================================
# LOGGING AND DEBUG
# =============================================================================

# Log level: debug, info, warn, error
LOG_LEVEL=info

# Log file path
LOG_FILE=~/.local/share/ergo/ergo.log

# Enable debug mode (verbose logging)
DEBUG_MODE=false

# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Enable git status tracking
ENABLE_GIT_TRACKING=true

# Enable shell command tracking
ENABLE_SHELL_TRACKING=true

# Enable browser tracking
ENABLE_BROWSER_TRACKING=false

# Enable build/test event tracking
ENABLE_BUILD_TRACKING=true

# =============================================================================
# SYSTEM SCANNING PERMISSIONS
# =============================================================================
# Explicitly grant authority for daemon to scan system resources
# See PERMISSIONS.md for detailed documentation

# Allow reading /proc filesystem for process information
ALLOW_PROC_SCAN=true

# Allow monitoring X11/Wayland windows via xdotool
ALLOW_WINDOW_MONITORING=true

# Allow reading shell history files
ALLOW_SHELL_HISTORY_READ=true

# Allow scanning git repositories in monitored directories
ALLOW_GIT_SCAN=true

# Allow reading file metadata (not contents) in project directories
ALLOW_FILE_METADATA_SCAN=true

# Paths that are explicitly allowed for scanning (comma-separated)
# Use absolute paths or ~ for home directory
# Example: ~/Documents,~/Projects,~/code
ALLOWED_SCAN_PATHS=~/Documents,~/Projects

# Paths that are explicitly forbidden from scanning (comma-separated)
# These take precedence over ALLOWED_SCAN_PATHS
FORBIDDEN_SCAN_PATHS=~/Documents/secrets,~/.ssh,~/.gnupg,~/.password-store

# Additional process names to monitor (comma-separated)
# Leave empty to monitor all non-ignored processes
# Example: nvim,code,firefox,chrome,terminal
MONITOR_PROCESSES=

# Maximum depth for directory scanning (prevents deep recursion)
MAX_SCAN_DEPTH=5
